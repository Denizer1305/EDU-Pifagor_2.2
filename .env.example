# ======================================
# GLOBAL
# ======================================
PROJECT_NAME=edu-pifagor
PROJECT_ENV=development

# ======================================
# BACKEND / DJANGO
# ======================================
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend
DJANGO_TIME_ZONE=Europe/Moscow

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True

# ======================================
# DATABASE
# ======================================
POSTGRES_DB=pifagor
POSTGRES_USER=pifagor_user
POSTGRES_PASSWORD=pifagor_password
DB_ENGINE=django.db.backends.postgresql
DB_HOST=db
DB_PORT=5432

# ======================================
# REDIS / CELERY
# ======================================
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ======================================
# EMAIL
# ======================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=example@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@edu-pifagor.ru

# ======================================
# FRONTEND
# ======================================
VITE_APP_NAME=Edu-Pifagor
VITE_API_BASE_URL=http://localhost:8000/api
